{
  "entities": {
    "Player": {
      "title": "Player",
      "description": "Ein Mitglied der Mannschaft mit Rollen und Kontostand.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "roles": { 
          "type": "array", 
          "items": { "type": "string", "enum": ["player", "admin", "kassenwart", "strafenwart", "coach", "assistant_coach"] } 
        },
        "balance": { "type": "number", "description": "Aktueller Kontostand der Getränkekasse." }
      },
      "required": ["name", "email", "roles", "balance"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Eine Getränkebuchung (Bier oder Kiste).",
      "type": "object",
      "properties": {
        "playerId": { "type": "string" },
        "playerName": { "type": "string" },
        "itemType": { "type": "string", "enum": ["beer", "crate"] },
        "cost": { "type": "number" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["playerId", "playerName", "itemType", "cost", "date"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Eine Einzahlung in die Getränkekasse.",
      "type": "object",
      "properties": {
        "playerId": { "type": "string" },
        "playerName": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "recordedBy": { "type": "string" }
      },
      "required": ["playerId", "playerName", "amount", "date", "recordedBy"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/players/{playerId}": {
      "schema": "#/backend/entities/Player",
      "description": "Profile der Teammitglieder."
    },
    "/expenses/{expenseId}": {
      "schema": "#/backend/entities/Expense",
      "description": "Historie der Getränkeentnahmen."
    },
    "/payments/{paymentId}": {
      "schema": "#/backend/entities/Payment",
      "description": "Historie der Einzahlungen."
    },
    "/membershipFees/{feeId}": {
      "schema": "object",
      "description": "Gezahlte Mitgliedsbeiträge."
    },
    "/fines/{fineId}": {
      "schema": "object",
      "description": "Vergebene Strafen."
    },
    "/teamEvents/{eventId}": {
      "schema": "object",
      "description": "Kalendereinträge für Training und Spiele."
    },
    "/settings/global": {
      "schema": "object",
      "description": "Globale App-Einstellungen (Preise, Links)."
    }
  }
}