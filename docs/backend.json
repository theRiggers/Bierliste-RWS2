{
  "entities": {
    "Player": {
      "title": "Player",
      "description": "Ein Mitglied der Mannschaft mit Rollen und Kontostand.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "roles": { "type": "array", "items": { "type": "string" } },
        "balance": { "type": "number" }
      },
      "required": ["name", "email", "roles", "balance"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Eine Getränke-Buchung (Bier oder Kiste).",
      "type": "object",
      "properties": {
        "playerId": { "type": "string" },
        "playerName": { "type": "string" },
        "itemType": { "type": "string", "enum": ["beer", "crate"] },
        "cost": { "type": "number" },
        "date": { "type": "string", "format": "date-time" }
      }
    },
    "Fine": {
      "title": "Fine",
      "description": "Eine verhängte Strafe aus dem Katalog.",
      "type": "object",
      "properties": {
        "playerId": { "type": "string" },
        "playerName": { "type": "string" },
        "reason": { "type": "string" },
        "amount": { "type": "number" },
        "isPaid": { "type": "boolean" },
        "date": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/players/{userId}": {
      "schema": "#/entities/Player",
      "description": "Nutzerprofile und Kontostände."
    },
    "/expenses/{expenseId}": {
      "schema": "#/entities/Expense",
      "description": "Getränke-Transaktionen."
    },
    "/fines/{fineId}": {
      "schema": "#/entities/Fine",
      "description": "Mannschaftsstrafen."
    }
  }
}