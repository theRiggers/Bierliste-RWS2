{
  "entities": {
    "Player": {
      "title": "Player",
      "description": "Ein Teammitglied mit Kontostand und Rollen.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "roles": { "type": "array", "items": { "type": "string" } },
        "balance": { "type": "number" }
      },
      "required": ["name", "email", "roles", "balance"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Eine Getränke-Buchung (Bier oder Kiste).",
      "type": "object",
      "properties": {
        "playerId": { "type": "string" },
        "playerName": { "type": "string" },
        "itemType": { "type": "string", "enum": ["beer", "crate"] },
        "cost": { "type": "number" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["playerId", "playerName", "itemType", "cost", "date"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Eine Einzahlung auf das Getränkekonto.",
      "type": "object",
      "properties": {
        "playerId": { "type": "string" },
        "playerName": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "recordedBy": { "type": "string" }
      },
      "required": ["playerId", "playerName", "amount", "date"]
    },
    "MembershipFee": {
      "title": "MembershipFee",
      "description": "Ein bezahlter Monats- oder Jahresbeitrag.",
      "type": "object",
      "properties": {
        "playerId": { "type": "string" },
        "type": { "type": "string", "enum": ["monthly", "annual"] },
        "month": { "type": "number" },
        "year": { "type": "number" },
        "amount": { "type": "number" },
        "datePaid": { "type": "string", "format": "date-time" }
      },
      "required": ["playerId", "type", "year", "amount", "datePaid"]
    },
    "TeamEvent": {
      "title": "TeamEvent",
      "description": "Ein Termin im Mannschaftskalender.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["training", "match", "social"] },
        "date": { "type": "string", "format": "date-time" },
        "location": { "type": "string" }
      },
      "required": ["title", "type", "date"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/players/{playerId}": {
      "schema": "#/backend/entities/Player",
      "description": "Profile der Spieler und Administratoren."
    },
    "/expenses/{expenseId}": {
      "schema": "#/backend/entities/Expense",
      "description": "Log aller Getränkeentnahmen."
    },
    "/payments/{paymentId}": {
      "schema": "#/backend/entities/Payment",
      "description": "Zahlungseingänge für Getränke."
    },
    "/membershipFees/{feeId}": {
      "schema": "#/backend/entities/MembershipFee",
      "description": "Beiträge zur Mannschaftskasse."
    },
    "/teamEvents/{eventId}": {
      "schema": "#/backend/entities/TeamEvent",
      "description": "Termine für Training, Spiele und Events."
    }
  }
}