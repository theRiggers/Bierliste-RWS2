{
  "entities": {
    "Player": {
      "title": "Player",
      "description": "Profil eines Spielers mit Kontostand und Rollen.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "roles": { 
          "type": "array", 
          "items": { "type": "string", "enum": ["player", "admin", "kassenwart", "strafenwart", "coach", "assistant_coach"] } 
        },
        "balance": { "type": "number" }
      },
      "required": ["name", "email", "roles", "balance"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Datensatz über einen Getränkekauf.",
      "type": "object",
      "properties": {
        "playerId": { "type": "string" },
        "playerName": { "type": "string" },
        "itemType": { "type": "string", "enum": ["beer", "crate"] },
        "cost": { "type": "number" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["playerId", "itemType", "cost", "date"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/players/{playerId}": {
      "schema": { "$ref": "#/entities/Player" },
      "description": "Sammlung der Spielerprofile."
    },
    "/expenses/{expenseId}": {
      "schema": { "$ref": "#/entities/Expense" },
      "description": "Sammlung der Getränkebuchungen."
    },
    "/settings/global": {
      "schema": "object",
      "description": "Globale App-Einstellungen."
    }
  }
}