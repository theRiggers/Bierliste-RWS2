
{
  "entities": {
    "Player": {
      "title": "Player",
      "description": "Ein Teammitglied oder Kassenprüfer.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["player", "auditor"] },
        "balance": { "type": "number", "description": "Aktueller Kontostand in Euro." }
      },
      "required": ["name", "email", "role", "balance"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Eine getätigte Getränkebuchung.",
      "type": "object",
      "properties": {
        "playerId": { "type": "string" },
        "playerName": { "type": "string" },
        "itemType": { "type": "string", "enum": ["beer", "crate"] },
        "cost": { "type": "number" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["playerId", "playerName", "itemType", "cost", "date"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Eine Einzahlung eines Spielers in die Kasse.",
      "type": "object",
      "properties": {
        "playerId": { "type": "string" },
        "playerName": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "recordedBy": { "type": "string", "description": "ID des Kassenprüfers, der die Zahlung erfasst hat." }
      },
      "required": ["playerId", "playerName", "amount", "date", "recordedBy"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/players/{playerId}": {
      "schema": "Player",
      "description": "Sammlung aller Spielerprofile."
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Verlauf aller getätigten Buchungen."
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Verlauf aller getätigten Einzahlungen."
    }
  }
}
