
{
  "entities": {
    "Player": {
      "title": "Player Profile",
      "description": "Profil eines Teammitglieds inklusive Rollen und Kontostand.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "roles": { 
          "type": "array", 
          "items": { "type": "string", "enum": ["player", "admin", "kassenwart", "strafenwart", "coach", "assistant_coach"] } 
        },
        "balance": { "type": "number", "description": "Aktueller Kontostand in Euro." }
      },
      "required": ["name", "email", "roles", "balance"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Ein einzelner Getränkekauf (Bier oder Kiste).",
      "type": "object",
      "properties": {
        "playerId": { "type": "string" },
        "playerName": { "type": "string" },
        "itemType": { "type": "string", "enum": ["beer", "crate"] },
        "cost": { "type": "number" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["playerId", "playerName", "itemType", "cost", "date"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Einzahlung eines Spielers in die Bierkasse.",
      "type": "object",
      "properties": {
        "playerId": { "type": "string" },
        "playerName": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "recordedBy": { "type": "string" }
      },
      "required": ["playerId", "playerName", "amount", "date", "recordedBy"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/players/{userId}": {
      "schema": "Player",
      "description": "Spielerprofile und Kontostände."
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Protokoll aller Getränkeentnahmen."
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Protokoll aller Einzahlungen."
    },
    "/membershipFees/{feeId}": {
      "schema": "object",
      "description": "Monats- und Jahresbeiträge."
    },
    "/membershipTransactions/{txId}": {
      "schema": "object",
      "description": "Sonstige Einnahmen/Ausgaben der Mannschaftskasse."
    },
    "/treasuryExpenses/{expId}": {
      "schema": "object",
      "description": "Ausgaben aus der Bierkasse (z.B. an das Vereinsheim)."
    },
    "/fines/{fineId}": {
      "schema": "object",
      "description": "Verhängte Strafen."
    },
    "/fineCatalog/{fineId}": {
      "schema": "object",
      "description": "Katalog der Vergehen."
    },
    "/teamEvents/{eventId}": {
      "schema": "object",
      "description": "Kalendertermine."
    },
    "/settings/global": {
      "schema": "object",
      "description": "Globale App-Einstellungen (Preise, Links)."
    }
  }
}
