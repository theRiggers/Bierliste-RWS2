
{
  "entities": {
    "Player": {
      "title": "Player",
      "description": "Ein Teammitglied mit Kontostand und Rollen.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "roles": { 
          "type": "array", 
          "items": { "type": "string", "enum": ["player", "admin", "kassenwart", "strafenwart", "coach", "assistant_coach"] } 
        },
        "balance": { "type": "number", "description": "Kontostand der Bierkasse." }
      },
      "required": ["name", "email", "roles", "balance"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Eine Getränkebuchung (Bier oder Kiste).",
      "type": "object",
      "properties": {
        "playerId": { "type": "string" },
        "playerName": { "type": "string" },
        "itemType": { "type": "string", "enum": ["beer", "crate"] },
        "cost": { "type": "number" },
        "date": { "type": "string", "format": "date-time" }
      }
    },
    "Payment": {
      "title": "Payment",
      "description": "Eine Einzahlung in die Bierkasse.",
      "type": "object",
      "properties": {
        "playerId": { "type": "string" },
        "playerName": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "recordedBy": { "type": "string" }
      }
    },
    "MembershipFee": {
      "title": "MembershipFee",
      "description": "Beitrag zur Mannschaftskasse.",
      "type": "object",
      "properties": {
        "playerId": { "type": "string" },
        "type": { "type": "string", "enum": ["monthly", "annual"] },
        "month": { "type": "number" },
        "year": { "type": "number" },
        "amount": { "type": "number" },
        "datePaid": { "type": "string", "format": "date-time" }
      }
    },
    "Fine": {
      "title": "Fine",
      "description": "Eine verhängte Strafe.",
      "type": "object",
      "properties": {
        "playerId": { "type": "string" },
        "playerName": { "type": "string" },
        "reason": { "type": "string" },
        "amount": { "type": "number" },
        "isPaid": { "type": "boolean" },
        "date": { "type": "string", "format": "date-time" }
      }
    },
    "TeamEvent": {
      "title": "TeamEvent",
      "description": "Ein Termin im Kalender.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["training", "match", "social"] },
        "date": { "type": "string", "format": "date-time" },
        "location": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/players/{userId}": {
      "schema": "Player",
      "description": "Nutzerprofile und Kontostände."
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Getränkebuchungen."
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Einzahlungen Bierkasse."
    },
    "/membershipFees/{feeId}": {
      "schema": "MembershipFee",
      "description": "Zahlungen Mannschaftskasse."
    },
    "/membershipTransactions/{txId}": {
      "schema": "object",
      "description": "Einnahmen/Ausgaben Mannschaftskasse."
    },
    "/treasuryExpenses/{expId}": {
      "schema": "object",
      "description": "Ausgaben der Bierkasse (z.B. Vereinsheim)."
    },
    "/fines/{fineId}": {
      "schema": "Fine",
      "description": "Verhängte Strafen."
    },
    "/fineCatalog/{fineTypeId}": {
      "schema": "object",
      "description": "Verfügbare Strafen-Typen."
    },
    "/teamEvents/{eventId}": {
      "schema": "TeamEvent",
      "description": "Kalendertermine."
    },
    "/settings/global": {
      "schema": "object",
      "description": "Globale App-Einstellungen."
    }
  }
}
